#!/usr/bin/env bash
set -euo pipefail

REPO="EHotwagner/Constitutions"
SRC_PATH=".specify/memory/constitution.md"
TARGET_DIR="${1:-.}"
DEST="${TARGET_DIR}/.specify/memory/constitution.md"

mkdir -p "$(dirname "$DEST")"

echo "Downloading constitution from ${REPO}..."
gh api "repos/${REPO}/contents/${SRC_PATH}" --jq '.content' | base64 -d > "$DEST"

echo "Written to ${DEST}"
