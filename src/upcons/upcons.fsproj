<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>upcons</ToolCommandName>
    <PackageId>upcons</PackageId>
    <Version>1.0.0</Version>
    <Description>Download and apply project constitutions from GitHub</Description>
    <PackageOutputPath>$(HOME)/.local/share/nuget-local</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
